%% for section in section_order
%% if section == 'education' and education
\section{Education}
\vspace{1pt}
%% for edu in education
\noindent\textbf{\VAR{ edu.institution | esc }, }\textit{\VAR{ edu.degree | esc }} \hfill \VAR{ edu.dates | esc }\par
