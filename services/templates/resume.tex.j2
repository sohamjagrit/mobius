\definecolor{accent}{HTML}{1F3A5F}
\definecolor{rule}{HTML}{B8C2CC}

\hypersetup{colorlinks=true, urlcolor=accent, linkcolor=accent, pdfborder={0 0 0}}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\setlength{\tabcolsep}{0pt}

\setlist[itemize]{leftmargin=1.2em, itemsep=1pt, topsep=2pt, parsep=2pt, label=\textcolor{accent}{\small\textbullet}}

\titleformat{\section}
  {\normalsize\bfseries\scshape}{}{0pt}{}[{\color{rule}\titlerule[1pt]}]
\titlespacing*{\section}{0pt}{1pt}{2.5pt}

\newcommand{\entryhead}[2]{\noindent\textbf{#1}\hfill#2\par}
\newcommand{\entrysub}[2]{\noindent\textit{#1}\hfill\textit{#2}\par}

\begin{document}

